# 소리톡 배포 환경변수 — 복사해서 .env 로 만들고 값을 채우세요 (.env 는 커밋 금지)
#   cp .env.example .env

# web 컨테이너를 노출할 호스트 포트 (http://서버IP:8080)
WEB_PORT=8080

# 호스트 MySQL — weekly 와 동일 DB 재사용(새 테이블 GameScore/StudyNote 는 prisma db push 로 자동 생성)
DATABASE_URL=mysql://root:비밀번호@host.docker.internal:3306/weekly_paper

# JWT 서명 키 (긴 랜덤 문자열)
JWT_SECRET=change_me_to_a_long_random_string

# 관리자 비밀번호 (광고 설정 / 시험정리 ingest)
ADMIN_PASSWORD=change_me

# Google Gemini API 키 (위클리 AI 코치)
GEMINI_API_KEY=your_gemini_api_key

# Threads(메타) 자동수집 — 비워두면 수집기 비활성
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_POLL_MINUTES=15
