# 위클리 페이퍼 환경변수 (실제 값은 .env.local 에 넣고 커밋하지 마세요)

# MySQL 연결 문자열 (Prisma)
DATABASE_URL="mysql://user:password@localhost:3306/weekly_paper"

# JWT 서명 비밀키
JWT_SECRET="change_me"

# Google Gemini API 키 (AI 코치)
GEMINI_API_KEY="your_gemini_api_key"

# 관리자 비밀번호 (광고/시험정리 ingest 등)
ADMIN_PASSWORD="change_me"

# Threads(메타) 시험정리 자동 수집 — 없으면 수집기 비활성
THREADS_ACCESS_TOKEN=""
THREADS_USER_ID=""
THREADS_POLL_MINUTES="15"
