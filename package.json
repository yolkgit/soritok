{
  "name": "soritok",
  "private": true,
  "version": "0.1.0",
  "description": "소리톡 모노레포 — 허브(책상) + 위클리 페이퍼 + 어린이 바둑교실",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:hub": "npm run dev -w apps/hub",
    "dev:weekly": "npm run dev -w apps/weekly",
    "dev:weekly-server": "npm run server -w apps/weekly",
    "dev:gnugo": "npm run dev -w apps/gnugo",
    "dev:games": "npm run dev -w apps/games",
    "build": "npm run build -w apps/hub && npm run build -w apps/gnugo && npm run build -w apps/games && npm run build -w apps/weekly",
    "build:hub": "npm run build -w apps/hub",
    "build:weekly": "npm run build -w apps/weekly",
    "build:gnugo": "npm run build -w apps/gnugo",
    "build:games": "npm run build -w apps/games"
  }
}
